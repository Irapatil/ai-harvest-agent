# ── Required ────────────────────────────────────────────────────────────────────
GEMINI_API_KEY=AIza...          # Google AI Studio → https://aistudio.google.com/apikey

# ── Auth (leave empty to disable) ───────────────────────────────────────────────
API_KEY=your-secret-key         # Clients must send  X-API-Key: <this value>

# ── Gemini model ─────────────────────────────────────────────────────────────────
GEMINI_MODEL=gemini-2.0-flash   # or gemini-1.5-pro for higher quality
GEMINI_MAX_RETRIES=3
GEMINI_TIMEOUT_SECS=30

# ── Service ──────────────────────────────────────────────────────────────────────
ENVIRONMENT=development         # development | staging | production
DEBUG=false
CORS_ORIGINS=*                  # comma-separated list of allowed origins
