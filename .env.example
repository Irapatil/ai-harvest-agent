# ── App ─────────────────────────────────────────────────────────────────────────
APP_NAME=AI Harvest Agent
APP_ENV=development          # development | staging | production
APP_DEBUG=true
APP_SECRET_KEY=change-me-in-production-32-chars-min
API_KEY=your-api-key-here    # clients must send X-API-Key: <value>
z
# ── Database ─────────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/harvest_db
# For local dev without Postgres:
# DATABASE_URL=sqlite+aiosqlite:///./harvest.db

# ── Redis ────────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ── Anthropic ────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-6
ANTHROPIC_MAX_TOKENS=8096

# ── Google Gemini ────────────────────────────────────────────────────────────────
GEMINI_API_KEY=AIza...
GEMINI_MODEL=gemini-2.0-flash

# ── Dice scraper (public board — no login required; leave blank unless using Easy Apply) ──
DICE_EMAIL=
DICE_PASSWORD=

# ── LinkedIn scraper ─────────────────────────────────────────────────────────────
LINKEDIN_SCRAPER_SLOW_MO_MS=600       # ms between Playwright actions (anti-bot)
LINKEDIN_DESCRIPTION_CONCURRENCY=3   # parallel detail-page tabs
LINKEDIN_HEADLESS=true
LINKEDIN_EMAIL=your-linkedin-email@example.com
LINKEDIN_PASSWORD=your-linkedin-password
# For accounts that log in via Microsoft or Google SSO.
# Leave blank to reuse LINKEDIN_EMAIL / LINKEDIN_PASSWORD for the SSO step.
MICROSOFT_EMAIL=
MICROSOFT_PASSWORD=

# ── Playwright ───────────────────────────────────────────────────────────────────
PLAYWRIGHT_BROWSER=chromium   # chromium | firefox | webkit
PLAYWRIGHT_HEADLESS=true
PLAYWRIGHT_TIMEOUT_MS=30000
PLAYWRIGHT_POOL_SIZE=3

# ── Storage ──────────────────────────────────────────────────────────────────────
STORAGE_BACKEND=local         # local | s3
STORAGE_LOCAL_DIR=./data/results
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# S3_BUCKET=harvest-results

# ── CORS ─────────────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://localhost:8080
