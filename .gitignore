# ── Environment & Secrets ─────────────────────────────────────────────────────
.env
.env.local
.env.production
*.env
!.env.example

# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/

# ── Virtual Environment ───────────────────────────────────────────────────────
.venv/
venv/
env/

# ── Pytest / Coverage ─────────────────────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/
.mypy_cache/

# ── Browser Sessions & Chrome Profiles (sensitive runtime data) ───────────────
data/sessions/*.json
data/chrome_profile/
data/chrome_profile_test/
data/chrome_profile_test2/
data/chrome_profile*/
storage_state/
*.json.lock

# ── Generated Harvest Results (runtime output — never commit) ─────────────────
data/results/
data/debug/

# ── Generated Root-Level Status & Result Files ────────────────────────────────
harvest_result.json
harvest_job_status.txt
prospect_result.json
prospect_job_status.txt

# ── Prospect Input Files (may contain personal data) ─────────────────────────
data/prospects/input/
!data/prospects/input/.gitkeep

# ── Logs ──────────────────────────────────────────────────────────────────────
*.log
server.err
server_stderr.log
server_stdout.log
uvicorn_out.txt
uvicorn_err.txt
logs/

# ── Playwright Debug Artifacts ────────────────────────────────────────────────
playwright-report/
test-results/
debug/

# ── IDE & OS ──────────────────────────────────────────────────────────────────
.vscode/
.idea/
.DS_Store
Thumbs.db
~$*

# ── Database ──────────────────────────────────────────────────────────────────
*.db
*.sqlite
*.sqlite3

# ── Generated Documents & Temp Files ─────────────────────────────────────────
data/*.docx
data/*.xlsx
data/*.csv
~*.tmp
*.tmp

# ── Build ─────────────────────────────────────────────────────────────────────
output/
exports/
reports/
